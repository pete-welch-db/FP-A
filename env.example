# =============================================================================
# Nova Molding Systems FP&A Demo — Environment Variables
# =============================================================================
# Copy this file to .env and fill in workspace-specific values.
# These values are used by the Databricks Asset Bundle (databricks.yml)
# and by the Streamlit app (app/app.yaml) at deploy time.
# =============================================================================

# Databricks workspace connection
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_TOKEN=dapi_XXXXXXXXXXXXXXXX
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse_id>

# Unity Catalog targeting
DATABRICKS_CATALOG=nova_molding_demo
DATABRICKS_SCHEMA=fpa

# SQL Warehouse ID (passed as DAB variable: --var warehouse_id=...)
WAREHOUSE_ID=<warehouse_id>

# Post-deployment IDs (populated after first pipeline run)
GENIE_SPACE_ID=<captured_after_deploy>
DASHBOARD_EMBED_URL=<captured_after_deploy>
DASHBOARD_EMBED_URL_V2=<captured_after_deploy>

# Feature flags
USE_MOCK_DATA=false

# Bundle target (dev | staging | prod)
BUNDLE_TARGET=dev
